# ─── Supabase ───────────────────────────────────────────────────────────────
# Project URL and anon key from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key for server-side writes (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# ─── GitHub App ─────────────────────────────────────────────────────────────
# Create at https://github.com/settings/apps/new
# Permissions:
#   - contents: read
#   - pull_requests: read
#   - metadata: read
#   - checks: write
# Subscribe to events: push, pull_request, installation
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Webhook secret you set on the App settings page
GITHUB_APP_WEBHOOK_SECRET=
# RSA private key — paste full PEM with literal \n for newlines, or use base64
GITHUB_APP_PRIVATE_KEY=

# ─── Claude API ─────────────────────────────────────────────────────────────
# Used to generate fix prompts. Get from console.anthropic.com
ANTHROPIC_API_KEY=
# Model id — keep on Sonnet for cost; Opus for complex business-logic checks
EDITH_FIX_PROMPT_MODEL=claude-sonnet-4-6

# ─── Inngest ────────────────────────────────────────────────────────────────
# Background job queue. inngest.com → Settings → keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── PayU (billing — India) ─────────────────────────────────────────────────
# Merchant credentials. payu.in → Merchant Dashboard
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
# Set to 'production' once live; otherwise stays in test mode
PAYU_MODE=test

# ─── App ────────────────────────────────────────────────────────────────────
# Base URL of this deployment (used in webhook URLs, OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for production. Generate with: openssl rand -base64 32
EDITH_SESSION_SECRET=

# ─── Google OAuth (Search Console integration — Tier 3 SEO) ────────────────
# Google Cloud Console → APIs & Services → Credentials → Web OAuth client
# Enable scopes: https://www.googleapis.com/auth/webmasters.readonly
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback — set
# explicitly only if you need to override for proxy/local setups.
GOOGLE_OAUTH_REDIRECT_URI=

# ─── Cron protection (Tier 5 SEO orchestrator) ──────────────────────────────
# Required for /api/cron/daily to run. Generate with:
#   openssl rand -base64 48
# Set the same value as a Vercel env var — Vercel cron sends it as
# `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# ─── Optional ───────────────────────────────────────────────────────────────
# Slack webhook for ops alerts (drift, billing failures)
SLACK_OPS_WEBHOOK_URL=
# Set to '1' to bypass real APIs and use the mock-data fixtures
EDITH_USE_FIXTURES=1
