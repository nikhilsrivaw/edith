# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============== dependencies ==============
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============== build / cache outputs ==============
/.next/
/out/
/build
/dist
.turbo
.swc
.cache
storybook-static

# ============== testing artifacts ==============
/coverage
/playwright-report
/test-results
cypress/screenshots
cypress/videos

# ============== misc ==============
.DS_Store
Thumbs.db
desktop.ini
*.pem
*.swp
*.swo
*~
*.bak
*.orig

# ============== logs ==============
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============== env files ==============
# All .env* ignored, except .env.example which documents the contract.
.env*
!.env.example

# ============== editor / IDE ==============
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.iml
.history

# ============== local / temp ==============
tmp
temp
.local
*.local
scratch
scratch.*

# ============== vercel ==============
.vercel

# ============== typescript ==============
*.tsbuildinfo
next-env.d.ts

# ============== EDITH-specific ==============
# Internal planning, integration setup, deploy checklists, etc. These
# reference internal project IDs, OAuth client IDs, and pending-rotation
# notes that don't belong in a public mirror. Keep them locally.
/docs/

# Supabase migrations — reference the production project ref in comments
# and the user keeps them applied directly via the Supabase SQL editor.
# Note: if you ever need to bootstrap a fresh DB, you'll need these files
# back from a local backup or version-controlled fork.
/supabase/migrations/

# Extension build output (generated by `pnpm --filter extension build`).
/extension/dist
/extension/popup/assets

# Memory / scratch files some workflows produce in repo
/.claude
.claude.local.md

# Anything obviously secret
*.secret
*.secrets
*credentials*.json
*serviceAccount*.json
